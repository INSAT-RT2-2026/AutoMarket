{% extends 'base.html.twig' %}

{% block title %}Cars - TunLuxAuto{% endblock %}

{% block body %}
<h1 style="color:#d4af37;">Our Collection</h1>

{% if cars is empty %}
    <p>No cars available at the moment.</p>
{% else %}
    <div style="display:grid; grid-template-columns: repeat(3, 1fr); gap:20px;">
    {% for car in cars %}
        <div style="background:#1a1a1a; padding:20px; border-radius:8px;">
            <h3>{{ car.brand }} {{ car.model }}</h3>
            <p>Year: {{ car.year }}</p>
            <p style="color:#d4af37;">{{ car.price }} TND</p>
            <a href="{{ path('car_show', {'id': car.id}) }}" style="color:#d4af37;">View Details</a>
        </div>
    {% endfor %}
    </div>
{% endif %}
{% endblock %}
